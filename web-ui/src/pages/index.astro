---
import "../styles/global.css";
import { App } from "../components/App";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <title>moreradicale</title>
    <meta
      name="description"
      content="moreradicale - CalDAV / CardDAV server admin interface"
    />
    <style>
      /* Loading state shown until React mounts (client:only).
         Mirrors the in-app login card visually so the transition
         doesn't flash a different layout. */
      :root { color-scheme: light dark; }
      html, body { margin: 0; padding: 0; height: 100%; }
      body {
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background: #ffffff;
        color: #0f172a;
      }
      @media (prefers-color-scheme: dark) {
        body { background: #020617; color: #f8fafc; }
      }
      .ui-bootstrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        gap: 1rem;
        opacity: 0;
        animation: ui-fade-in 0.4s ease-out 0.15s forwards;
      }
      .ui-bootstrap-logo {
        width: 3rem;
        height: 3rem;
        border-radius: 0.875rem;
        background: #3b82f6;
        color: #fff;
        display: grid;
        place-items: center;
        animation: ui-pulse 1.6s ease-in-out infinite;
      }
      .ui-bootstrap-logo svg { width: 1.5rem; height: 1.5rem; }
      .ui-bootstrap-text {
        font-size: 0.875rem;
        opacity: 0.6;
      }
      @keyframes ui-fade-in {
        to { opacity: 1; }
      }
      @keyframes ui-pulse {
        0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.45); }
        50% { transform: scale(1.04); box-shadow: 0 0 0 14px rgba(59, 130, 246, 0); }
      }
    </style>
  </head>
  <body>
    <App client:only="react">
      <div slot="fallback" class="ui-bootstrap" role="status" aria-live="polite">
        <div class="ui-bootstrap-logo" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8 2v4"/><path d="M16 2v4"/>
            <rect width="18" height="18" x="3" y="4" rx="2"/>
            <path d="M3 10h18"/>
            <path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/>
            <path d="M8 18h.01"/><path d="M12 18h.01"/><path d="M16 18h.01"/>
          </svg>
        </div>
        <div class="ui-bootstrap-text">Loading moreradicale...</div>
      </div>
    </App>
  </body>
</html>
