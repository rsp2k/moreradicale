---
import "../styles/global.css";
import { App } from "../components/App";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <title>moreradicale</title>
    <meta
      name="description"
      content="moreradicale - CalDAV / CardDAV server admin interface"
    />
    <style>
      /* Loading state shown until React mounts (client:only). */
      .ui-bootstrap {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        gap: 0.75rem;
        color: color-mix(in oklab, currentColor 60%, transparent);
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        font-size: 0.875rem;
      }
      .ui-bootstrap-spinner {
        width: 1.25rem;
        height: 1.25rem;
        border: 2px solid currentColor;
        border-top-color: transparent;
        border-radius: 50%;
        animation: ui-spin 0.7s linear infinite;
      }
      @keyframes ui-spin {
        to { transform: rotate(360deg); }
      }
    </style>
  </head>
  <body>
    <App client:only="react">
      <div slot="fallback" class="ui-bootstrap">
        <div class="ui-bootstrap-spinner" aria-hidden="true"></div>
        <span>Loading moreradicale...</span>
      </div>
    </App>
  </body>
</html>
